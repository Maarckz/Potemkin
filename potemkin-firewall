#!/bin/bash
# =============================================================================
# potemkin-firewall
# =============================================================================

set -Eeuo pipefail

CHAIN="POTEMKIN"

log() {
    logger -t potemkin-firewall "$*"
}

validate_ip() {
    local ip="$1"

    [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || {
        echo "ERROR: IP invalido: $ip" >&2
        exit 1
    }

    local IFS='.'
    read -ra octets <<< "$ip"

    for octet in "${octets[@]}"; do
        ((octet >= 0 && octet <= 255)) || {
            echo "ERROR: Octeto invalido: $octet" >&2
            exit 1
        }
    done
}

validate_duration() {
    local dur="$1"

    [[ "$dur" =~ ^[0-9]+$ ]] || exit 1
    ((dur >= 1 && dur <= 86400)) || exit 1
}

validate_backend() {
    [[ "$1" == "iptables" ]] || {
        echo "Backend invalido"
        exit 1
    }
}

validate_chain() {
    [[ "$1" =~ ^[A-Za-z0-9_-]+$ ]] || {
        echo "Chain invalida"
        exit 1
    }
}

iptables_setup() {

    local chain="$1"

    iptables -N "$chain" 2>/dev/null || true

    iptables -F "$chain"

    if ! iptables -C "$chain" -j RETURN 2>/dev/null; then
        iptables -A "$chain" -j RETURN
    fi

    if ! iptables -C INPUT -j "$chain" 2>/dev/null; then
        iptables -I INPUT -j "$chain"
    fi
}

iptables_block() {

    local ip="$1"
    local duration="$2"

    #############################################
    ## Remove qualquer regra antiga do IP ##
    #############################################

    while iptables -C "$CHAIN" -s "$ip" -j DROP 2>/dev/null; do
        iptables -D "$CHAIN" -s "$ip" -j DROP
    done

    local comment="PTM:$(date +%s):${duration}"

    iptables -I "$CHAIN" \
        -s "$ip" \
        -m comment \
        --comment "$comment" \
        -j DROP

    log "BLOCK $ip"
}

iptables_unblock() {

    local ip="$1"

    #############################################
    ## Remove TODAS as regras para o IP ##
    #############################################

    while true; do

        local line

        line=$(
            iptables -S "$CHAIN" \
            | grep -- "-s ${ip}" \
            | grep -- "-j DROP" \
            || true
        )

        [[ -z "$line" ]] && break

        line="${line#-A $CHAIN }"

        if ! iptables -D "$CHAIN" $line; then
            echo "Falha removendo regra: $line" >&2
            exit 1
        fi

    done

    #############################################
    ## Verificacao ##
    #############################################

    if iptables -S "$CHAIN" | grep -q -- "-s ${ip}"; then
        echo "Ainda existe regra para $ip" >&2
        exit 1
    fi

    log "UNBLOCK $ip"
}

iptables_cleanup() {

    local chain="$1"

    iptables -D INPUT -j "$chain" 2>/dev/null || true

    iptables -F "$chain" 2>/dev/null || true

    iptables -X "$chain" 2>/dev/null || true
}

COMMAND="${1:-}"
BACKEND="${2:-}"
TARGET="${3:-}"
EXTRA="${4:-}"

case "$COMMAND" in

setup)

    validate_backend "$BACKEND"
    validate_chain "$TARGET"
    iptables_setup "$TARGET"
    ;;

block)

    validate_backend "$BACKEND"
    validate_ip "$TARGET"
    validate_duration "$EXTRA"

    iptables_block "$TARGET" "$EXTRA"
    ;;

unblock)

    validate_backend "$BACKEND"
    validate_ip "$TARGET"

    iptables_unblock "$TARGET"
    ;;

cleanup)

    validate_backend "$BACKEND"
    validate_chain "$TARGET"

    iptables_cleanup "$TARGET"
    ;;

*)

    echo "Uso: potemkin-firewall {setup|block|unblock|cleanup}" >&2
    exit 1
    ;;

esac

exit 0
