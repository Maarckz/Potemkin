<!-- 
  Wazuh Rules para Potemkin Honeypot
  Instale no Manager em: /var/ossec/etc/rules/potemkin_rules.xml 
-->
<group name="potemkin,honeypot,">

  <!-- Regra Base (Level 3 - Apenas para agrupar) -->
  <rule id="100500" level="3">
    <decoded_as>potemkin</decoded_as>
    <description>Potemkin Honeypot event.</description>
  </rule>

  <!-- Conexão em Porta Falsa (Level 4 - Aviso) -->
  <rule id="100501" level="4">
    <if_sid>100500</if_sid>
    <field name="event">connection</field>
    <description>Potemkin: Honeypot connection detected on port $(dst_port) from $(src_ip)</description>
    <mitre>
      <id>T1046</id> <!-- Network Service Discovery -->
    </mitre>
    <group>reconnaissance,</group>
  </rule>

  <!-- Portscan Detectado (Level 8 - Alerta) -->
  <rule id="100502" level="8">
    <if_sid>100500</if_sid>
    <field name="event">scan_detected</field>
    <description>Potemkin: Portscan detected from $(src_ip) ($(port_count) ports in time window)</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>reconnaissance,attack,</group>
  </rule>

  <!-- Bloqueio no IPTables (Level 10 - Crítico/Ação) -->
  <rule id="100503" level="10">
    <if_sid>100500</if_sid>
    <field name="event">ip_blocked</field>
    <description>Potemkin: IP $(src_ip) BLOCKED for $(duration)s (reason: $(reason))</description>
    <mitre>
      <id>T1498</id> <!-- Network Denial of Service (mitigation action) -->
    </mitre>
    <group>active_response,attack,</group>
  </rule>

  <!-- Desbloqueio (Level 3 - Informativo) -->
  <rule id="100504" level="3">
    <if_sid>100500</if_sid>
    <field name="event">ip_unblocked</field>
    <description>Potemkin: IP $(src_ip) ban expired, UNBLOCKED.</description>
  </rule>

</group>
